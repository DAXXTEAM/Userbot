async def main():
    await app.start()
    me = await app.get_me()
    print(f"Userbot started! Logged in as {me.first_name} (ID: {me.id})")
    await idle()
    await app.stop()


if __name__ == "__main__":
    loop = asyncio.get_event_loop()
    loop.run_until_complete(main())
